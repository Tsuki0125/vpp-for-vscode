{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VPP",
  "scopeName": "source.vpp",
  "patterns": [
    { "include": "#vpp-block-comment" },
    { "include": "#vpp-line-comment" },
    { "include": "#verilog-line-comment" },
    { "include": "#verilog-block-comment" },
    { "include": "#script-block" },
    { "include": "#vpp-directives" },
    { "include": "#vpp-variable-reference" },
    { "include": "#vpp-builtin-functions" },
    { "include": "#vpp-string" },
    { "include": "#verilog-numbers" },
    { "include": "#verilog-keywords" },
    { "include": "#verilog-types" },
    { "include": "#verilog-system-tasks" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "vpp-block-comment": {
      "name": "comment.block.vpp",
      "begin": "^\\s*`/\\*",
      "end": "^\\s*`\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.vpp" } },
      "endCaptures": { "0": { "name": "punctuation.definition.comment.end.vpp" } }
    },
    "vpp-line-comment": {
      "name": "comment.line.vpp",
      "match": "^\\s*`//.*$",
      "captures": { "0": { "name": "comment.line.double-slash.vpp" } }
    },
    "verilog-line-comment": {
      "name": "comment.line.double-slash.verilog",
      "match": "(?<!`)//.*$"
    },
    "verilog-block-comment": {
      "name": "comment.block.verilog",
      "begin": "(?<!`)/\\*",
      "end": "\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.verilog" } },
      "endCaptures": { "0": { "name": "punctuation.definition.comment.end.verilog" } }
    },
    "script-block": {
      "name": "meta.embedded.block.javascript.vpp",
      "begin": "^<script>\\s*$",
      "end": "^</script>\\s*$",
      "beginCaptures": { "0": { "name": "keyword.control.script.begin.vpp" } },
      "endCaptures": { "0": { "name": "keyword.control.script.end.vpp" } },
      "patterns": [
        { "include": "source.js" }
      ]
    },
    "vpp-directives": {
      "patterns": [
        { "include": "#vpp-control-flow" },
        { "include": "#vpp-iteration" },
        { "include": "#vpp-definition" },
        { "include": "#vpp-function-def" },
        { "include": "#vpp-include" },
        { "include": "#vpp-special-directives" },
        { "include": "#vpp-continuation" }
      ]
    },
    "vpp-control-flow": {
      "patterns": [
        {
          "name": "keyword.control.conditional.vpp",
          "match": "`(if|else|elseif|endif|ifdef|ifndef|iflet|ifnlet)\\b"
        },
        {
          "name": "keyword.control.switch.vpp",
          "match": "`(switch|case|breaksw|default|endswitch|endsw)\\b"
        }
      ]
    },
    "vpp-iteration": {
      "name": "keyword.control.loop.vpp",
      "match": "`(for|endfor|while|endwhile|fori|endfori)\\b"
    },
    "vpp-definition": {
      "patterns": [
        {
          "name": "keyword.other.define.vpp",
          "match": "`(define|definex|let|eval|configure)\\b"
        },
        {
          "name": "keyword.other.deflines.vpp",
          "match": "`(deflines|enddeflines)\\b"
        }
      ]
    },
    "vpp-function-def": {
      "name": "keyword.control.function.vpp",
      "match": "`(func|endfunc)\\b"
    },
    "vpp-include": {
      "patterns": [
        {
          "name": "keyword.control.import.vpp",
          "match": "`(include_1xi|include_xi|include_s|include|incdir|subst)\\b"
        }
      ]
    },
    "vpp-special-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.vpp",
          "match": "`(error|warning|undef|timescale|celldefine|endcelldefine|resetall)\\b"
        },
        {
          "name": "constant.language.predefined.vpp",
          "match": "`(__FYLE__|__LYNE__)\\b"
        }
      ]
    },
    "vpp-continuation": {
      "name": "keyword.operator.continuation.vpp",
      "match": "`[/\\\\]\\s*$"
    },
    "vpp-variable-reference": {
      "patterns": [
        {
          "name": "variable.other.vpp",
          "match": "`[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.computed.vpp",
          "begin": "`\\(",
          "end": "\\)",
          "beginCaptures": { "0": { "name": "punctuation.definition.variable.begin.vpp" } },
          "endCaptures": { "0": { "name": "punctuation.definition.variable.end.vpp" } },
          "patterns": [
            { "include": "#vpp-string" },
            { "include": "#vpp-variable-reference" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "vpp-builtin-functions": {
      "name": "support.function.builtin.vpp",
      "match": "\\b(MAX|MIN|ABS|CEIL|FLOOR|LOG2CEIL|LOG2|JS|INCLUDE_EXISTS|FILE_EXISTS|VPP_defines|VPP_args|ERASE_INPUT_LINES|ERASE_OUTPUT_LINES|VPP_services)\\b"
    },
    "vpp-string": {
      "name": "string.quoted.double.vpp",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.vpp" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.vpp" } },
      "patterns": [
        {
          "name": "constant.character.escape.vpp",
          "match": "\\\\."
        },
        {
          "name": "variable.other.vpp.interpolated",
          "match": "`[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "verilog-numbers": {
      "patterns": [
        {
          "name": "constant.numeric.verilog-sized.vpp",
          "match": "\\b[0-9]+'[bBoOdDhH][0-9a-fA-F_xXzZ]+\\b"
        },
        {
          "name": "constant.numeric.verilog-unsized.vpp",
          "match": "'[bBoOdDhH][0-9a-fA-F_xXzZ]+\\b"
        },
        {
          "name": "constant.numeric.real.vpp",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.vpp",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "verilog-keywords": {
      "patterns": [
        {
          "name": "keyword.verilog.block.vpp",
          "match": "\\b(module|endmodule|begin|end|generate|endgenerate|task|endtask|function|endfunction|class|endclass|package|endpackage|program|endprogram|interface|endinterface|clocking|endclocking|property|endproperty|sequence|endsequence|checker|endchecker|config|endconfig|primitive|endprimitive|specify|endspecify|table|endtable|covergroup|endgroup)\\b"
        },
        {
          "name": "keyword.verilog.control.vpp",
          "match": "\\b(always|always_comb|always_ff|always_latch|initial|final|assign|deassign|force|release|if|else|unique|unique0|priority|case|casex|casez|endcase|default|for|foreach|while|do|repeat|forever|return|break|continue|fork|join|join_any|join_none|wait|wait_order|disable|posedge|negedge|edge|iff|inside|with|assert|assume|cover|expect|restrict|before|throughout|within|intersect|first_match|triggers|accept_on|reject_on|sync_accept_on|sync_reject_on)\\b"
        },
        {
          "name": "keyword.verilog.declaration.vpp",
          "match": "\\b(input|output|inout|ref|parameter|localparam|defparam|genvar|var|const|automatic|static|virtual|extern|pure|import|export|typedef|enum|struct|union|packed|signed|unsigned|void|rand|randc|constraint|solve|soft|type|extends|implements|new|super|this|local|protected|null|tagged|modport|bind|alias|nettype)\\b"
        },
        {
          "name": "keyword.verilog.coverage.vpp",
          "match": "\\b(coverpoint|cross|bins|illegal_bins|ignore_bins|wildcard|binsof|option|type_option|sample)\\b"
        },
        {
          "name": "keyword.verilog.timing.vpp",
          "match": "\\b(timeprecision|timeunit)\\b"
        }
      ]
    },
    "verilog-types": {
      "name": "storage.type.verilog.vpp",
      "match": "\\b(wire|reg|logic|bit|byte|shortint|int|longint|integer|real|realtime|time|shortreal|string|chandle|event|supply0|supply1|tri|triand|trior|tri0|tri1|trireg|wand|wor|uwire|interconnect|untyped|semaphore|mailbox|process|virtual)\\b"
    },
    "verilog-system-tasks": {
      "name": "support.function.system.verilog.vpp",
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_$]*"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.concat.vpp",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.vpp",
          "match": "===|!==|==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.vpp",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.vpp",
          "match": "~|&|\\||\\^|<<|>>"
        },
        {
          "name": "keyword.operator.arithmetic.vpp",
          "match": "\\+\\+|--|[+\\-*/%]"
        },
        {
          "name": "keyword.operator.ternary.vpp",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.assignment.vpp",
          "match": "="
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.vpp",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.vpp",
          "match": ";"
        }
      ]
    }
  }
}
