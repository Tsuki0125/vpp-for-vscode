// ============================================================
// JavaScript integration
// ============================================================
<script>
var extensions = [
    { name: "rsc", description: "read and shred card", opcode: 7 },
    { name: "era", description: "erase disk", opcode: 9 },
];
</script>

`let E = JS("extensions")
`for (`i = 0; `i < `E.length; `i++)
    `let ext = `E[`i]
    `let name = `ext.name
    `let opc = `ext.opcode
    module `name(clk);
    endmodule
`endfor

// ============================================================
// Verilog module with VPP
// ============================================================
module cache_ctrl (
    input wire clk,
    input wire rst_n,
    `for (`w = 0; `w < `IC_WAYS; `w++)
    input wire [`DATA_RANGE] way`w::_data,
    `endfor
    output reg [`DATA_RANGE] selected_data
);

    always_comb begin
        `switch (`IC_WAYS)
            `case 2
                selected_data = way_sel ? way1_data : way0_data;
            `breaksw
            `case 4
                case (way_sel)
                    2'b00: selected_data = way0_data;
                    2'b01: selected_data = way1_data;
                    2'b10: selected_data = way2_data;
                    2'b11: selected_data = way3_data;
                endcase
            `breaksw
        `endswitch
    end

endmodule

// ============================================================
// Built-in functions
// ============================================================
`let bits = LOG2CEIL(`IC_WAYS)
`let max_val = MAX(256, 512, 1024)
`let min_val = MIN(`IC_WAYS, 8)

