`// This is a VPP comment (won't appear in output)

`define IC_WAYS 4
`define IC_TRAM_RANGE 15:0
`define DATA_RANGE 31:0

`let TAG = "tague"
`let ncpus = 3

// ============================================================
// For loop example
// ============================================================
`for (`i = 0; `i < `IC_WAYS; `i++)
    wire [`IC_TRAM_RANGE] `TAG::_mem_rdata`i;
`endfor

// ============================================================
// While loop example
// ============================================================
`let i = 0
`while (`i < `IC_WAYS)
    wire [`IC_TRAM_RANGE] tag_mem_rdata`i;
    `let i = `i + 1
`endwhile

// ============================================================
// Conditional example
// ============================================================
`ifdef HAS_ICACHE
    `if `IC_WAYS > 2
        wire [3:0] way_select;
    `elseif `IC_WAYS == 2
        wire way_select;
    `else
        // single way, no select needed
    `endif
`endif

// ============================================================
// Switch example
// ============================================================
`switch (`PER_BUS_OPTION)
    `case 1
        .dbu_per_ahb_hlock    (dbu_per_ahb_hlock),
    `breaksw

    `case 0
        .dbu_per_bvci_cmdval  (dbu_per_bvci_cmdval),
    `breaksw

    `default
        // default case
`endswitch

// ============================================================
// Function example
// ============================================================
`func FF TOP Z
    `for (`ix = 0; `ix < `TOP; `ix++)
        `ix `Z
    `endfor
`endfunc

`FF(5, 4)

// ============================================================
// Iterator (fori) example
// ============================================================
`func upto yield lo hi
    `for (`ix = `lo; `ix <= `hi; `ix++)
        `yield(`ix)
    `endfor
`endfunc

`fori val : `upto(1, 3)
    // number is `val
`endfori

// ============================================================
// deflines example
// ============================================================
`deflines not_basecase
    begin
        basecase_inst = 1'b0;
    end
`enddeflines

